{
  "name": "publications",
  "version": "1.0.0",
  "description": "Research publications site",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "run-s lint:*",
    "lint:text": "textlint \"docs/**/*.md\"",
    "lint:text:fix": "textlint --fix \"docs/**/*.md\"",
    "lint:link": "markdown-link-check docs/**/*.md --config .markdown-link-check.json"
  },
  "license": "MIT",
  "devDependencies": {
    "markdown-it-mathjax3": "^4.3.2",
    "markdown-it-plantuml": "^1.4.1",
    "markdown-link-check": "^3.14.2",
    "mermaid": "^11.12.2",
    "npm-run-all2": "^8.0.4",
    "textlint": "^15.5.2",
    "textlint-rule-no-empty-section": "^1.1.0",
    "textlint-rule-no-todo": "^2.0.1",
    "vitepress": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
